# Copy to .env.local and fill in real values. NEVER commit real secrets.

# --- Web ---
# Host port for the Carta Digital preview. Never use 3330 (Reservas Tauras).
WEB_PORT=3331

# --- Database (PostgreSQL 18, isolated from Reservas) ---
POSTGRES_USER=cartadigital
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=cartadigital
# In containers host is `db`; from host vs dev compose use localhost:5433.
DATABASE_URL=postgresql://cartadigital:change-me-strong-password@db:5432/cartadigital?schema=public

# --- Admin auth ---
# Min 32 chars. Generate: openssl rand -base64 48
SESSION_SECRET=change-me-to-a-long-random-string-min-32-chars
# Store ONLY a bcrypt hash, never a plaintext password.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash
